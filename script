-- ─── Настройки ────────────────────────────────────────────────
local ENEMY_DANGER_RADIUS    = 20
local SAFE_FROM_ENEMY_RADIUS = 35
local MAX_TELEPORT_DIST      = 150
local MIN_TELEPORT_DIST      = 6
local CHECK_INTERVAL         = 0.5
local TELEPORT_COOLDOWN      = 2.0
local SLIDE_STEP_SIZE        = 4
local SLIDE_STEP_DELAY       = 0.05
local PLAYER_HEIGHT          = 3.0
local RAY_DOWN_DIST          = 40
local RAY_UP_OFFSET          = 10
local HIGHLIGHT_FILL         = Color3.fromRGB(255, 30, 30)
local HIGHLIGHT_OUTLINE      = Color3.fromRGB(255, 160, 0)
-- ──────────────────────────────────────────────────────────────

local scriptEnabled    = true
local teleportCooldown = false

