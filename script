-- LocalScript | StarterPlayerScripts
-- Подсветка enemy + пошаговый безопасный телепорт (anti-cheat friendly)

local Players      = game:GetService("Players")
local RunService   = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace    = game:GetService("Workspace")
local TweenService = game:GetService("TweenService")

local player    = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local playerGui = player:WaitForChild("PlayerGui")

local MAP              = Workspace:WaitForChild("Map")
local ENTITIES_FOLDER  = MAP:WaitForChild("Entities")
local PLACEABLE_FOLDER = MAP:WaitForChild("Placeable")

-- ─── Настройки ────────────────────────────────────────────────
local ENEMY_DANGER_RADIUS    = 20    -- радиус угрозы от enemy
local SAFE_FROM_ENEMY_RADIUS = 35    -- мин. дистанция от enemy у цели
local MAX_TELEPORT_DIST      = 150   -- макс. дальность поиска точки (можно далеко)
local MIN_TELEPORT_DIST      = 6
local CHECK_INTERVAL         = 0.5

local STEP_SIZE              = 8     -- studs за один шаг (anti-cheat friendly)
local STEP_DELAY             = 0.07  -- секунды между шагами
local TELEPORT_COOLDOWN      = 2.0   -- cooldown после телепорта

local HIGHLIGHT_FILL         = Color3.fromRGB(255, 30, 30)
local HIGHLIGHT_OUTLINE      = Color3.fromRGB(255, 160, 0)
-- ──────────────────────────────────────────────────────────────

local scriptEnabled    = true
local teleportCooldown = false

-- ═══════════════════════════════════════════════════════════════
-- GUI: кнопка включения/выключения
-- ═══════════════════════════════════════════════════════════════
local screenGui = Instance.new("ScreenGui")
screenGui.Name             = "SafeTPGui"
screenGui.ResetOnSpawn     = false
screenGui.ZIndexBehavior   = Enum.ZIndexBehavior.Sibling
screenGui.Parent           = playerGui

local btn = Instance.new("TextButton")
btn.Size            = UDim2.new(0, 160, 0, 40)
btn.Position        = UDim2.new(1, -170, 0, 10) -- правый верхний угол
btn.AnchorPoint     = Vector2.new(0, 0)
btn.BackgroundColor3 = Color3.fromRGB(40, 180, 80)
btn.TextColor3      = Color3.fromRGB(255, 255, 255)
btn.Text            = "✅ SafeTP: ВКЛ"
btn.Font            = Enum.Font.GothamBold
btn.TextSize        = 15
btn.BorderSizePixel = 0
btn.Parent          = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 10)
corner.Parent       = btn

local function updateButton()
	if scriptEnabled then
		btn.BackgroundColor3 = Color3.fromRGB(40, 180, 80)
		btn.Text             = "✅ SafeTP: ВКЛ"
	else
		btn.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
		btn.Text             = "❌ SafeTP: ВЫКЛ"
	end
end

btn.MouseButton1Click:Connect(function()
	scriptEnabled = not scriptEnabled
	updateButton()
	print("[SafeTP] Скрипт:", scriptEnabled and "ВКЛЮЧЁН" or "ВЫКЛЮЧЁН")
end)

-- Также Toggle на клавишу F5
UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode.F5 then
		scriptEnabled = not scriptEnabled
		updateButton()
		print("[SafeTP] Скрипт:", scriptEnabled and "ВКЛЮЧЁН" or "ВЫКЛЮЧЁН")
	end
end)

-- ═══════════════════════════════════════════════════════════════
-- Подсветка enemy
-- ═══════════════════════════════════════════════════════════════
local function isEnemy(model)
	return model.Name:lower():sub(1, 5) == "enemy"
end

local function addHighlight(model)
	if model:FindFirstChildOfClass("Highlight") then return end
	local hl = Instance.new("Highlight")
	hl.FillColor           = HIGHLIGHT_FILL
	hl.OutlineColor        = HIGHLIGHT_OUTLINE
	hl.FillTransparency    = 0.45
	hl.OutlineTransparency = 0
	hl.Adornee             = model
	hl.Parent              = model
end

local function highlightAllEnemies()
	for _, model in ipairs(ENTITIES_FOLDER:GetChildren()) do
		if model:IsA("Model") and isEnemy(model) then
			addHighlight(model)
		end
	end
end

ENTITIES_FOLDER.ChildAdded:Connect(function(child)
	task.wait(0.1)
	if child:IsA("Model") and isEnemy(child) then
		addHighlight(child)
	end
end)

-- ═══════════════════════════════════════════════════════════════
-- Логика поиска безопасной позиции
-- ═══════════════════════════════════════════════════════════════
local function getEnemyPositions()
	local positions = {}
	for _, model in ipairs(ENTITIES_FOLDER:GetChildren()) do
		if model:IsA("Model") and isEnemy(model) then
			local root = model:FindFirstChild("HumanoidRootPart")
				or model.PrimaryPart
				or model:FindFirstChildOfClass("BasePart")
			if root then
				table.insert(positions, root.Position)
			end
		end
	end
	return positions
end

local function isSafeFromEnemies(pos, enemyPositions)
	for _, ep in ipairs(enemyPositions) do
		if (pos - ep).Magnitude < SAFE_FROM_ENEMY_RADIUS then
			return false
		end
	end
	return true
end

local function getSurfaceBelow(pos, ignoreList)
	local params = RaycastParams.new()
	params.FilterDescendantsInstances = ignoreList
	params.FilterType = Enum.RaycastFilterType.Exclude
	local result = Workspace:Raycast(pos + Vector3.new(0, 4, 0), Vector3.new(0, -12, 0), params)
	return result and result.Position or nil
end

local function findSafeTarget(playerPos, enemyPositions, ignoreList)
	local candidates = {}

	for _, part in ipairs(PLACEABLE_FOLDER:GetDescendants()) do
		if part:IsA("BasePart") then
			local targetPos = part.Position + Vector3.new(0, part.Size.Y / 2 + 3.5, 0)
			local dist      = (targetPos - playerPos).Magnitude

			if dist >= MIN_TELEPORT_DIST and dist <= MAX_TELEPORT_DIST then
				table.insert(candidates, { pos = targetPos, dist = dist })
			end
		end
	end

	-- Сортируем по расстоянию (ближние первые)
	table.sort(candidates, function(a, b) return a.dist < b.dist end)

	for _, c in ipairs(candidates) do
		local surface = getSurfaceBelow(c.pos, ignoreList)
		if surface and isSafeFromEnemies(c.pos, enemyPositions) then
			return surface + Vector3.new(0, 3, 0)
		end
	end

	return nil
end

-- ═══════════════════════════════════════════════════════════════
-- Пошаговый телепорт (anti-cheat friendly)
-- Перемещает игрока маленькими шагами по STEP_SIZE studs
-- ═══════════════════════════════════════════════════════════════
local function stepTeleport(hrp, targetPos)
	local currentPos = hrp.Position

	-- Считаем сколько шагов нужно
	local totalDist = (targetPos - currentPos).Magnitude
	local steps     = math.ceil(totalDist / STEP_SIZE)

	for i = 1, steps do
		-- Проверяем что персонаж ещё жив
		local char = player.Character
		if not char then break end
		local h = char:FindFirstChildOfClass("Humanoid")
		if not h or h.Health <= 0 then break end

		local alpha    = i / steps
		local stepPos  = currentPos:Lerp(targetPos, alpha)

		-- Ищем поверхность на каждом промежуточном шаге
		local ignoreList = { char }
		local surface = getSurfaceBelow(stepPos, ignoreList)
		if surface then
			stepPos = surface + Vector3.new(0, 3, 0)
		end

		hrp.CFrame = CFrame.new(stepPos)
		task.wait(STEP_DELAY)
	end

	-- Финальная точная установка
	hrp.CFrame = CFrame.new(targetPos)
end

-- ═══════════════════════════════════════════════════════════════
-- Главный цикл
-- ═══════════════════════════════════════════════════════════════
local lastCheck = 0

RunService.Heartbeat:Connect(function()
	if not scriptEnabled then return end
	if tick() - lastCheck < CHECK_INTERVAL then return end
	lastCheck = tick()
	if teleportCooldown then return end

	character = player.Character
	if not character then return end

	local hrp      = character:FindFirstChild("HumanoidRootPart")
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not hrp or not humanoid or humanoid.Health <= 0 then return end

	-- Проверяем угрозу
	local enemyPositions = getEnemyPositions()
	local playerPos      = hrp.Position
	local inDanger       = false

	for _, ep in ipairs(enemyPositions) do
		if (playerPos - ep).Magnitude < ENEMY_DANGER_RADIUS then
			inDanger = true
			break
		end
	end

	if not inDanger then return end

	-- Ищем безопасную точку
	local ignoreList = { character }
	local safePos    = findSafeTarget(playerPos, enemyPositions, ignoreList)

	if safePos then
		teleportCooldown = true
		print("[SafeTP] Телепортирую по шагам →", safePos)
		task.spawn(function()
			stepTeleport(hrp, safePos)
			task.wait(TELEPORT_COOLDOWN)
			teleportCooldown = false
		end)
	else
		print("[SafeTP] Безопасная точка не найдена!")
	end
end)

player.CharacterAdded:Connect(function(newChar)
	character = newChar
end)

-- Запуск
highlightAllEnemies()
print("[SafeTP] Скрипт запущен. Кнопка справа вверху / F5 — toggle.")
